# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5440
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=twinanalytics

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
